{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "JSON to CSV Converter",
  "version": "1.0.0",
  "identifier": "com.leecaiy04.json2csv",
  "build": {
    "frontendDist": "../"
  },
  "app": {
    "windows": [
      {
        "title": "JSON to CSV Converter",
        "width": 1200,
        "height": 800,
        "resizable": true,
        "center": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/icon.png"
    ],
    "category": "Utility",
    "shortDescription": "JSON to CSV/Excel converter",
    "longDescription": "A pure frontend JSON to CSV/Excel converter with drag-drop support",
    "copyright": "Copyright (c) 2026"
  }
}
